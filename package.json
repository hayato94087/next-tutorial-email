{
  "name": "next-tutorial",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint && prisma validate",
    "lint:fix": "next lint --fix",
    "format": "prettier --check \"**/*.{ts,tsx,js,jsx,cjs,mjs,md,json,lintstagedrc,yml,yaml}\"",
    "format:fix": "prettier --write \"**/*.{ts,tsx,js,jsx,cjs,mjs,md,json,lintstagedrc,yml,yaml}\" && prisma format",
    "typecheck": "tsc --noEmit",
    "clean": "git clean -xdf node_modules dist",
    "prepare": "husky",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "email:dev": "email dev -d ./src/emails -p 3001"
  },
  "prisma": {
    "seed": "pnpm vite-node prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "@react-email/components": "0.0.32",
    "@t3-oss/env-nextjs": "^0.11.1",
    "next": "15.1.2",
    "prisma": "^6.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^4.1.1",
    "zod": "^3.24.1",
    "zod-prisma-types": "^3.2.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@ianvs/prettier-plugin-sort-imports": "^4.4.0",
    "@types/eslint": "^9.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "eslint": "^9",
    "eslint-config-next": "15.1.2",
    "eslint-plugin-unicorn": "^56.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "postcss": "^8",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "react-email": "3.0.6",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vite-node": "^2.1.8"
  }
}
